{
  "Ollama": {
    "BaseUrl": "http://localhost:11434",
    "EmbeddingModel": "nomic-embed-text",
    "GenerationModel": "qwen2.5:0.5b",
    "RequestTimeoutSeconds": 120,
    "StreamingTimeoutSeconds": 300
  },
  "Chroma": {
    "BaseUrl": "http://localhost:8000",
    "DefaultCollection": "portfolio-docs",
    "EmbeddingDimension": 768
  },
  "Rag": {
    "DefaultTopK": 5,
    "MaxContextTokens": 3000,
    "ChunkSize": 400,
    "ChunkOverlap": 80,
    "MinChunkLength": 50
  },
  "Cors": {
    "AllowedOrigins": [
      "http://localhost:3000",
      "http://127.0.0.1:3000",
      "https://nihar840.github.io",
      "https://niharranjan.com"
    ]
  },
  "Logging": {
    "LogLevel": {
      "Default": "Information",
      "Microsoft.AspNetCore": "Warning"
    }
  },
  "AllowedHosts": "*"
}
