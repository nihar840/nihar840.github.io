---
export interface Props {
  title?: string;
  description?: string;
}

const {
  title = 'Nihar Ranjan — Software Engineer & Tech Lead',
  description = 'Full-stack engineer and tech lead shipping enterprise products in the Microsoft ecosystem — React, .NET, Python, Azure',
} = Astro.props;
---

<!doctype html>
<html lang="en">
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1" />
    <meta name="description" content={description} />
    <meta name="theme-color" content="#0d0d0d" />

    <!-- Open Graph -->
    <meta property="og:title" content={title} />
    <meta property="og:description" content={description} />
    <meta property="og:type" content="website" />
    <meta property="og:url" content="https://niharranjan.com" />
    <meta property="og:image" content="https://niharranjan.com/Images/Profile pic.jpg" />

    <!-- Favicon — NR. style matching header logo -->
    <link rel="icon" type="image/svg+xml" href="/favicon.svg" />
    <link rel="shortcut icon" href="/favicon.ico" />

    <title>{title}</title>
  </head>
  <body>
    <slot />
  </body>
</html>
