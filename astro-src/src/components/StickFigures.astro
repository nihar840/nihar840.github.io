---
// StickFigures.astro — The Crew of Tiny Ninjas
// position:fixed, pointer-events:none, above zones, below toggle
---

<div class="sf-stage" aria-hidden="true">

  <!--
    RUNNER 1 — runs left→right across bottom
    Arms and legs animated with SVG transform-box
  -->
  <div class="sf sf-runner1">
    <svg class="sf-svg" viewBox="0 0 44 64" width="44" height="64">
      <!-- Head + smile -->
      <circle cx="22" cy="9" r="8" stroke="#0d0d0d" stroke-width="2.8" fill="#fff"/>
      <path d="M18 11 Q22 15 26 11" fill="none" stroke="#0d0d0d" stroke-width="1.5" stroke-linecap="round"/>
      <!-- Eyes -->
      <circle cx="19" cy="8" r="1.2" fill="#0d0d0d"/>
      <circle cx="25" cy="8" r="1.2" fill="#0d0d0d"/>
      <!-- Body -->
      <line x1="22" y1="17" x2="22" y2="40" stroke="#0d0d0d" stroke-width="2.8" stroke-linecap="round"/>
      <!-- Arms -->
      <g class="sf-arm-l" style="transform-origin: 22px 24px; transform-box: fill-box;">
        <line x1="22" y1="24" x2="7" y2="34" stroke="#0d0d0d" stroke-width="2.5" stroke-linecap="round"/>
        <line x1="7" y1="34" x2="3" y2="42" stroke="#0d0d0d" stroke-width="2" stroke-linecap="round"/>
      </g>
      <g class="sf-arm-r" style="transform-origin: 22px 24px; transform-box: fill-box;">
        <line x1="22" y1="24" x2="37" y2="34" stroke="#0d0d0d" stroke-width="2.5" stroke-linecap="round"/>
        <line x1="37" y1="34" x2="41" y2="42" stroke="#0d0d0d" stroke-width="2" stroke-linecap="round"/>
      </g>
      <!-- Legs -->
      <g class="sf-leg-l" style="transform-origin: 22px 40px; transform-box: fill-box;">
        <line x1="22" y1="40" x2="12" y2="55" stroke="#0d0d0d" stroke-width="2.8" stroke-linecap="round"/>
        <line x1="12" y1="55" x2="8"  y2="63" stroke="#0d0d0d" stroke-width="2.2" stroke-linecap="round"/>
      </g>
      <g class="sf-leg-r" style="transform-origin: 22px 40px; transform-box: fill-box;">
        <line x1="22" y1="40" x2="32" y2="55" stroke="#0d0d0d" stroke-width="2.8" stroke-linecap="round"/>
        <line x1="32" y1="55" x2="36" y2="63" stroke="#0d0d0d" stroke-width="2.2" stroke-linecap="round"/>
      </g>
    </svg>
  </div>

  <!--
    RUNNER 2 — runs right→left (mirrored), higher on screen
    Wearing a hat!
  -->
  <div class="sf sf-runner2">
    <svg class="sf-svg" viewBox="0 0 44 72" width="38" height="58">
      <!-- Straw hat -->
      <ellipse cx="22" cy="7" rx="16" ry="4" fill="#c8871a" stroke="#6b3a00" stroke-width="2"/>
      <path d="M10 7 Q10 0 22 -1 Q34 0 34 7Z" fill="#f4a261" stroke="#6b3a00" stroke-width="2"/>
      <rect x="10" y="4" width="24" height="5" rx="2" fill="#e63946" stroke="#6b3a00" stroke-width="1.5"/>
      <!-- Head -->
      <circle cx="22" cy="16" r="7.5" stroke="#0d0d0d" stroke-width="2.5" fill="#fde8c9"/>
      <!-- Big grin -->
      <path d="M16 18 Q22 24 28 18" fill="none" stroke="#0d0d0d" stroke-width="2" stroke-linecap="round"/>
      <path d="M16 18 Q22 24 28 18" fill="white" stroke="none"/>
      <!-- Eyes shut (happy run) -->
      <path d="M17 14 Q19 12 21 14" fill="none" stroke="#0d0d0d" stroke-width="1.5"/>
      <path d="M23 14 Q25 12 27 14" fill="none" stroke="#0d0d0d" stroke-width="1.5"/>
      <!-- Scar -->
      <path d="M14 16 L18 20" stroke="#e63946" stroke-width="2" stroke-linecap="round"/>
      <!-- Body -->
      <line x1="22" y1="24" x2="22" y2="47" stroke="#0d0d0d" stroke-width="2.8" stroke-linecap="round"/>
      <!-- Arms -->
      <g class="sf-arm-l" style="transform-origin: 22px 30px; transform-box: fill-box;">
        <line x1="22" y1="30" x2="7"  y2="40" stroke="#0d0d0d" stroke-width="2.5" stroke-linecap="round"/>
      </g>
      <g class="sf-arm-r" style="transform-origin: 22px 30px; transform-box: fill-box;">
        <line x1="22" y1="30" x2="37" y2="40" stroke="#0d0d0d" stroke-width="2.5" stroke-linecap="round"/>
      </g>
      <!-- Legs -->
      <g class="sf-leg-l" style="transform-origin: 22px 47px; transform-box: fill-box;">
        <line x1="22" y1="47" x2="12" y2="62" stroke="#0d0d0d" stroke-width="2.8" stroke-linecap="round"/>
      </g>
      <g class="sf-leg-r" style="transform-origin: 22px 47px; transform-box: fill-box;">
        <line x1="22" y1="47" x2="32" y2="62" stroke="#0d0d0d" stroke-width="2.8" stroke-linecap="round"/>
      </g>
    </svg>
  </div>

  <!--
    JUMPER — bounces at right side of screen
    Speech bubble: "SHIP IT!"
  -->
  <div class="sf sf-jumper">
    <!-- Speech bubble above -->
    <div class="sf-bubble">SHIP IT! ⚡</div>
    <svg class="sf-svg" viewBox="0 0 44 64" width="40" height="60">
      <circle cx="22" cy="9" r="8" stroke="#6366f1" stroke-width="2.8" fill="#eef2ff"/>
      <circle cx="18.5" cy="7.5" r="1.5" fill="#6366f1"/>
      <circle cx="25.5" cy="7.5" r="1.5" fill="#6366f1"/>
      <path d="M17 12 Q22 16 27 12" fill="none" stroke="#6366f1" stroke-width="2" stroke-linecap="round"/>
      <line x1="22" y1="17" x2="22" y2="40" stroke="#6366f1" stroke-width="2.8" stroke-linecap="round"/>
      <!-- Arms up (excited) -->
      <line x1="22" y1="24" x2="6"  y2="14" stroke="#6366f1" stroke-width="2.5" stroke-linecap="round"/>
      <line x1="22" y1="24" x2="38" y2="14" stroke="#6366f1" stroke-width="2.5" stroke-linecap="round"/>
      <!-- Legs -->
      <g class="sf-leg-l" style="transform-origin: 22px 40px; transform-box: fill-box;">
        <line x1="22" y1="40" x2="12" y2="55" stroke="#6366f1" stroke-width="2.8" stroke-linecap="round"/>
      </g>
      <g class="sf-leg-r" style="transform-origin: 22px 40px; transform-box: fill-box;">
        <line x1="22" y1="40" x2="32" y2="55" stroke="#6366f1" stroke-width="2.8" stroke-linecap="round"/>
      </g>
    </svg>
  </div>

  <!--
    WAVER — sits at bottom-left corner, waves
  -->
  <div class="sf sf-waver">
    <div class="sf-bubble sf-bubble--left">Nakama! 🏴‍☠️</div>
    <svg class="sf-svg" viewBox="0 0 60 80" width="52" height="68">
      <!-- Sitting body -->
      <circle cx="30" cy="10" r="9" stroke="#e63946" stroke-width="2.8" fill="#fff5f5"/>
      <circle cx="26" cy="8"  r="1.5" fill="#e63946"/>
      <circle cx="34" cy="8"  r="1.5" fill="#e63946"/>
      <path d="M25 13 Q30 18 35 13" fill="none" stroke="#e63946" stroke-width="2" stroke-linecap="round"/>
      <!-- Body -->
      <line x1="30" y1="19" x2="30" y2="42" stroke="#e63946" stroke-width="2.8" stroke-linecap="round"/>
      <!-- Waving arm -->
      <g class="sf-wave-arm" style="transform-origin: 30px 26px; transform-box: fill-box;">
        <line x1="30" y1="26" x2="50" y2="16" stroke="#e63946" stroke-width="2.5" stroke-linecap="round"/>
        <line x1="50" y1="16" x2="57" y2="8"  stroke="#e63946" stroke-width="2"   stroke-linecap="round"/>
      </g>
      <!-- Other arm resting -->
      <line x1="30" y1="26" x2="14" y2="34" stroke="#e63946" stroke-width="2.5" stroke-linecap="round"/>
      <!-- Sitting legs -->
      <line x1="30" y1="42" x2="15" y2="56" stroke="#e63946" stroke-width="2.8" stroke-linecap="round"/>
      <line x1="15" y1="56" x2="6"  y2="56" stroke="#e63946" stroke-width="2.5" stroke-linecap="round"/>
      <line x1="30" y1="42" x2="45" y2="56" stroke="#e63946" stroke-width="2.8" stroke-linecap="round"/>
      <line x1="45" y1="56" x2="54" y2="56" stroke="#e63946" stroke-width="2.5" stroke-linecap="round"/>
    </svg>
  </div>

  <!--
    TINY ONE at top — does a cartwheel across
  -->
  <div class="sf sf-cartwheel">
    <svg class="sf-svg" viewBox="0 0 36 52" width="30" height="42">
      <circle cx="18" cy="8" r="6.5" stroke="#10b981" stroke-width="2.5" fill="#ecfdf5"/>
      <line x1="18" y1="15" x2="18" y2="34" stroke="#10b981" stroke-width="2.5" stroke-linecap="round"/>
      <line x1="18" y1="22" x2="5"  y2="30" stroke="#10b981" stroke-width="2.2" stroke-linecap="round"/>
      <line x1="18" y1="22" x2="31" y2="30" stroke="#10b981" stroke-width="2.2" stroke-linecap="round"/>
      <line x1="18" y1="34" x2="8"  y2="48" stroke="#10b981" stroke-width="2.5" stroke-linecap="round"/>
      <line x1="18" y1="34" x2="28" y2="48" stroke="#10b981" stroke-width="2.5" stroke-linecap="round"/>
    </svg>
  </div>

</div>

<style>
/* ── Stage wrapper ── */
.sf-stage {
  position: fixed;
  inset: 0;
  pointer-events: none;
  z-index: 9990;          /* above zones, below toggle (9999) */
  overflow: hidden;
}

/* ── Base figure ── */
.sf {
  position: absolute;
}

.sf-svg {
  display: block;
  filter: drop-shadow(1px 2px 3px rgba(0,0,0,0.15));
}

/* ── Speech bubbles ── */
.sf-bubble {
  position: absolute;
  bottom: calc(100% + 6px);
  left: 50%;
  transform: translateX(-50%);
  background: white;
  border: 2px solid #0d0d0d;
  border-radius: 10px;
  padding: 4px 10px;
  font-family: 'Bangers', Impact, cursive;
  font-size: 11px;
  letter-spacing: 0.06em;
  color: #0d0d0d;
  white-space: nowrap;
  box-shadow: 2px 2px 0 #0d0d0d;
}
.sf-bubble::after {
  content: '';
  position: absolute;
  top: 100%;
  left: 40%;
  border: 6px solid transparent;
  border-top-color: #0d0d0d;
}
.sf-bubble--left {
  left: 20px;
  transform: none;
}

/* ─────────────────────────────────────────
   RUNNER 1 — bottom strip, L→R, 14s loop
─────────────────────────────────────────── */
.sf-runner1 {
  bottom: 16px;
  animation: run-right 14s linear 1s infinite;
}
.sf-runner1 .sf-svg {
  animation: body-bob 0.4s ease-in-out infinite;
}
.sf-runner1 .sf-arm-l { animation: arm-fwd  0.4s ease-in-out infinite; }
.sf-runner1 .sf-arm-r { animation: arm-back 0.4s ease-in-out infinite; }
.sf-runner1 .sf-leg-l { animation: leg-fwd  0.4s ease-in-out infinite; }
.sf-runner1 .sf-leg-r { animation: leg-back 0.4s ease-in-out infinite; }

/* ─────────────────────────────────────────
   RUNNER 2 — higher strip, R→L, Luffy hat
─────────────────────────────────────────── */
.sf-runner2 {
  bottom: 80px;
  right: -80px;
  animation: run-left 18s linear 4s infinite;
}
.sf-runner2 .sf-svg {
  transform: scaleX(-1);
  animation: body-bob-flip 0.38s ease-in-out infinite;
}
.sf-runner2 .sf-arm-l { animation: arm-back 0.38s ease-in-out infinite; }
.sf-runner2 .sf-arm-r { animation: arm-fwd  0.38s ease-in-out infinite; }
.sf-runner2 .sf-leg-l { animation: leg-back 0.38s ease-in-out infinite; }
.sf-runner2 .sf-leg-r { animation: leg-fwd  0.38s ease-in-out infinite; }

/* ─────────────────────────────────────────
   JUMPER — right side, mid height
─────────────────────────────────────────── */
.sf-jumper {
  right: 16px;
  bottom: 160px;
  animation: do-jump 2.2s cubic-bezier(0.4,0,0.6,1) 0.5s infinite;
}
.sf-jumper .sf-leg-l { animation: leg-back 0.55s ease-in-out infinite; }
.sf-jumper .sf-leg-r { animation: leg-fwd  0.55s ease-in-out infinite; }

/* ─────────────────────────────────────────
   WAVER — bottom-left corner, waves
─────────────────────────────────────────── */
.sf-waver {
  left: 20px;
  bottom: 20px;
  animation: idle-sway 3s ease-in-out infinite;
}
.sf-wave-arm {
  animation: do-wave 1.2s ease-in-out infinite;
}

/* ─────────────────────────────────────────
   CARTWHEEL — top strip, L→R slowly
─────────────────────────────────────────── */
.sf-cartwheel {
  top: 80px;
  animation: run-right 22s linear 8s infinite;
}
.sf-cartwheel .sf-svg {
  animation: spin-slow 1.8s linear infinite;
}

/* ── Responsive: hide some on small screens ── */
@media (max-width: 640px) {
  .sf-cartwheel { display: none; }
  .sf-runner2   { display: none; }
}
@media (max-width: 400px) {
  .sf-jumper { display: none; }
}
</style>
