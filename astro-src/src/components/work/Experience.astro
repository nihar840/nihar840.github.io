---

<section class="section" id="experience">
  <div class="container">
    <div class="chapter-label">Chapter 03 · The Journey</div>
    <div class="section-heading">
      <h2>Experience</h2>
      <p>Enterprise battles won, systems shipped, teams led.</p>
    </div>

    <div class="timeline">
      {experience.map((exp) => (
        <div class="timeline-item">
          <div class="timeline-dot" style={`background: ${exp.color}`}></div>
          <div class="timeline-card manga-panel">
            <div class="timeline-card__role">{exp.role}</div>
            <div class="timeline-card__company">{exp.company}</div>
            <div class="timeline-card__meta">
              <span>📅 {exp.period}</span>
              <span>📍 {exp.location}</span>
            </div>
            <ul class="timeline-card__highlights">
              {exp.highlights.map(h => <li>{h}</li>)}
            </ul>
          </div>
        </div>
      ))}
    </div>
  </div>
</section>

<div class="halftone-divider container"></div>
