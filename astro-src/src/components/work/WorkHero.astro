---
// WorkHero.astro — Chapter 01: The Navigator

const stats = [
  { value: '7+',     label: 'Years Exp.' },
  { value: '4',      label: 'Companies'  },
  { value: 'M365',   label: 'Platform'   },
  { value: 'AZ-900', label: 'Certified'  },
];

const highlights = [
  { icon: '🏢', text: 'Microsoft — Cosmic Portal (AI)', sub: 'Redmond, WA · 2025–Present' },
  { icon: '⚡', text: 'Tech Mahindra — M365 FastTrack', sub: 'Redmond, WA · 2021–2025' },
  { icon: '🛢️', text: 'Infosys — BP RIO & Walmart', sub: 'India · 2018–2021' },
];

const stack = ['React', 'TypeScript', '.NET', 'Python', 'Azure', 'Cosmos DB', 'RAG / AI'];
---

<section class="work-hero section">
  <div class="speed-lines"></div>
  <div class="paper-texture"></div>

  <div class="container work-hero__inner">
    <!-- Profile Photo -->
    <div class="work-hero__photo-wrap anim-ink-drop">
      <img
        src="/Images/Profile pic.jpg"
        alt="Nihar Ranjan — Software Engineer"
        class="work-hero__photo"
        width="220"
        height="220"
        loading="eager"
        fetchpriority="high"
      />
      <div class="work-hero__photo-ring"></div>

      <!-- Location badge -->
      <div class="hero-location-badge">
        📍 Redmond, WA
      </div>
    </div>

    <!-- Content -->
    <div class="work-hero__content">
      <div class="chapter-label work-hero__chapter">Chapter 01 · The Navigator</div>

      <h1 class="work-hero__name anim-panel-in">
        NIHAR<br/>RANJAN
      </h1>

      <p class="work-hero__title">
        Software Engineer &amp; Tech Lead
      </p>

      <!-- Quick Stats Bar -->
      <div class="hero-stats">
        {stats.map(s => (
          <div class="hero-stat">
            <span class="hero-stat__val">{s.value}</span>
            <span class="hero-stat__lbl">{s.label}</span>
          </div>
        ))}
      </div>

      <!-- Mini Experience Panel -->
      <div class="hero-exp-panel manga-panel">
        {highlights.map(h => (
          <div class="hero-exp-row">
            <span class="hero-exp-row__icon">{h.icon}</span>
            <div>
              <div class="hero-exp-row__text">{h.text}</div>
              <div class="hero-exp-row__sub">{h.sub}</div>
            </div>
          </div>
        ))}
      </div>

      <!-- Stack chips -->
      <div class="hero-stack">
        {stack.map(t => <span class="hero-stack__chip">{t}</span>)}
      </div>

      <div class="work-hero__bubble" style="margin-top: 16px;">
        <div class="speech-bubble">
          "I want to build great things!" ⚡
        </div>
      </div>

      <div class="work-hero__actions" style="margin-top: 20px;">
        <a href="/resume.pdf" download class="btn-manga btn-manga--primary">
          ↓ Download Profile
        </a>
        <a href="#contact" class="btn-manga btn-manga--secondary">
          ✉ Contact Me
        </a>
      </div>

      <div class="work-hero__socials">
        <a href="https://www.linkedin.com/in/ranjannihar/" target="_blank" rel="noopener" title="LinkedIn">
          <i class="fa-brands fa-linkedin"></i>
        </a>
        <a href="https://github.com/nihar840" target="_blank" rel="noopener" title="GitHub">
          <i class="fa-brands fa-github"></i>
        </a>
        <a href="https://www.instagram.com/n_i_h_a_r_m_a_h_a_j_a_n/" target="_blank" rel="noopener" title="Instagram">
          <i class="fa-brands fa-instagram"></i>
        </a>
        <a href="mailto:nrmahajan840@gmail.com" title="Email">
          <i class="fa-solid fa-envelope"></i>
        </a>
      </div>
    </div>
  </div>
</section>

<div class="halftone-divider container"></div>

<style>
/* ─── Hero Stats Bar ─── */
.hero-stats {
  display: flex;
  gap: 0;
  margin: 14px 0 16px;
  background: var(--paper-dark, #e8e0d0);
  border: 2.5px solid var(--ink);
  border-radius: 8px;
  overflow: hidden;
  box-shadow: 4px 4px 0 var(--ink);
  width: fit-content;
}

.hero-stat {
  display: flex;
  flex-direction: column;
  align-items: center;
  padding: 10px 18px;
  border-right: 2px solid var(--ink);
  min-width: 72px;
}
.hero-stat:last-child { border-right: none; }

.hero-stat__val {
  font-family: var(--font-manga);
  font-size: 20px;
  color: var(--accent);
  line-height: 1;
  letter-spacing: 0.03em;
}

.hero-stat__lbl {
  font-size: 9px;
  font-weight: 700;
  color: var(--ink-soft);
  letter-spacing: 0.08em;
  text-transform: uppercase;
  margin-top: 3px;
}

/* ─── Mini Experience Panel ─── */
.hero-exp-panel {
  padding: 12px 14px;
  margin-bottom: 14px;
  display: flex;
  flex-direction: column;
  gap: 8px;
  max-width: 460px;
}

.hero-exp-row {
  display: flex;
  align-items: flex-start;
  gap: 10px;
}

.hero-exp-row__icon { font-size: 16px; flex-shrink: 0; margin-top: 1px; }

.hero-exp-row__text {
  font-size: 12px;
  font-weight: 700;
  color: var(--ink);
  line-height: 1.3;
}

.hero-exp-row__sub {
  font-size: 10px;
  color: #64748b;
  margin-top: 1px;
}

/* ─── Stack chips ─── */
.hero-stack {
  display: flex;
  flex-wrap: wrap;
  gap: 5px;
  margin-bottom: 14px;
}

.hero-stack__chip {
  font-size: 10px;
  font-weight: 700;
  letter-spacing: 0.05em;
  padding: 3px 10px;
  border-radius: 20px;
  background: white;
  border: 2px solid var(--ink);
  color: var(--ink);
  box-shadow: 2px 2px 0 var(--ink);
}

/* ─── Location badge ─── */
.hero-location-badge {
  position: absolute;
  bottom: -10px;
  left: 50%;
  transform: translateX(-50%);
  background: var(--ink);
  color: white;
  font-size: 10px;
  font-weight: 700;
  padding: 4px 12px;
  border-radius: 20px;
  white-space: nowrap;
  letter-spacing: 0.04em;
}

/* Mobile: stack on top */
@media (max-width: 640px) {
  .hero-stats { width: 100%; }
  .hero-stat { flex: 1; padding: 8px 10px; min-width: unset; }
  .hero-stat__val { font-size: 16px; }
  .hero-exp-panel { max-width: 100%; }
}
</style>
