          </svg>
        </a>
      </div>
    </div>
  </div>
</section>

<div class="halftone-divider container"></div>

<style>
/* ─── Pixel Rain Canvas ─── */
#hero-pixel-rain {
  position: absolute;
  inset: 0;
  width: 100%;
  height: 100%;
  pointer-events: none;
  z-index: 0;
}

/* Ensure hero content sits above canvas */
.work-hero .speed-lines,
.work-hero .paper-texture,
.work-hero__inner {
  position: relative;
  z-index: 1;
}

/* ─── Typing cursor ─── */
.typing-cursor {
  display: inline-block;
  margin-left: 1px;
  color: var(--accent);
  font-weight: 700;
  animation: cursor-blink 0.85s step-end infinite;
}
@keyframes cursor-blink {
  0%, 100% { opacity: 1; }
  50%       { opacity: 0; }
}

/* ─── Hero Stats Bar ─── */
.hero-stats {
  display: flex;
  gap: 0;
  margin: 14px 0 16px;
  background: var(--paper-dark, #e8e0d0);
  border: 2.5px solid var(--ink);
  border-radius: 8px;
  overflow: hidden;
  box-shadow: 4px 4px 0 var(--ink);
  width: fit-content;
}

.hero-stat {
  display: flex;
  flex-direction: column;
  align-items: center;
  padding: 10px 18px;
  border-right: 2px solid var(--ink);
  min-width: 72px;
}
.hero-stat:last-child { border-right: none; }

.hero-stat__val {
  font-family: var(--font-manga);
  font-size: 20px;
  color: var(--accent);
  line-height: 1;
  letter-spacing: 0.03em;
}

.hero-stat__lbl {
  font-size: 9px;
  font-weight: 700;
  color: var(--ink-soft);
  letter-spacing: 0.08em;
  text-transform: uppercase;
  margin-top: 3px;
}

/* ─── Mini Experience Panel ─── */
.hero-exp-panel {
  padding: 12px 14px;
  margin-bottom: 14px;
  display: flex;
  flex-direction: column;
  gap: 8px;
  max-width: 460px;
}

.hero-exp-row {
  display: flex;
  align-items: flex-start;
  gap: 10px;
}

.hero-exp-row__icon { font-size: 16px; flex-shrink: 0; margin-top: 1px; }

.hero-exp-row__text {
  font-size: 12px;
  font-weight: 700;
  color: var(--ink);
  line-height: 1.3;
}

.hero-exp-row__sub {
  font-size: 10px;
  color: #4b5563;
  margin-top: 1px;
}

/* ─── Stack chips ─── */
.hero-stack {
  display: flex;
  flex-wrap: wrap;
  gap: 5px;
  margin-bottom: 14px;
}

.hero-stack__chip {
  font-size: 10px;
  font-weight: 700;
  letter-spacing: 0.05em;
  padding: 3px 10px;
  border-radius: 20px;
  background: white;
  border: 2px solid var(--ink);
  color: var(--ink);
  box-shadow: 2px 2px 0 var(--ink);
}

/* ─── Location badge ─── */
.hero-location-badge {
  position: absolute;
  bottom: -10px;
  left: 50%;
  transform: translateX(-50%);
  background: var(--ink);
  color: white;
  font-size: 10px;
  font-weight: 700;
  padding: 4px 12px;
  border-radius: 20px;
  white-space: nowrap;
  letter-spacing: 0.04em;
}

/* ─── Social icons ─── */
.work-hero__socials svg {
  display: block;
}

/* Mobile */
@media (max-width: 640px) {
  .hero-stats { width: 100%; }
  .hero-stat { flex: 1; padding: 8px 10px; min-width: unset; }
  .hero-stat__val { font-size: 16px; }
  .hero-exp-panel { max-width: 100%; }
}
</style>

<script>
/* ══════════════════════════════════════════
   WORK HERO — Typing effect + Pixel rain
   ══════════════════════════════════════════ */

/* ── TYPING EFFECT ──────────────────────── */
(function initTyping() {
  const el = document.getElementById('hero-typing-text');
  if (!el) return;

  const TITLES = [
    'Software Engineer',
    'Tech Lead',
    'AI Systems Builder',
    'React & .NET Dev',
    'Cloud Architect',
    'Full-Stack Engineer',
    'RAG / LLM Builder',
  ];

  let idx = 0, charIdx = 0, deleting = false;

  function step() {
    const current = TITLES[idx];
    if (!deleting) {
      el.textContent = current.slice(0, charIdx + 1);
      charIdx++;
      if (charIdx === current.length) {
        deleting = true;
        setTimeout(step, 1800); // hold at full word
        return;
      }
      setTimeout(step, 60 + Math.random() * 30); // ~60–90ms per char
    } else {
      el.textContent = current.slice(0, charIdx - 1);
      charIdx--;
      if (charIdx === 0) {
        deleting = false;
        idx = (idx + 1) % TITLES.length;
        setTimeout(step, 320);
        return;
      }
      setTimeout(step, 30 + Math.random() * 15); // delete faster
    }
  }

  step();
})();

/* ── PIXEL RAIN ─────────────────────────── */
(function initPixelRain() {
  const canvas = document.getElementById('hero-pixel-rain') as HTMLCanvasElement | null;
  if (!canvas) return;

  const section = canvas.closest('.work-hero') as HTMLElement | null;
  if (!section) return;

  const ctx = canvas.getContext('2d');
  if (!ctx) return;

  // Manga palette — low opacity so content stays readable
  const COLORS = ['#e63946', '#6366f1', '#111111', '#2b2d42', '#f4a261'];
  const COUNT   = 55; // number of pixel squares

  // getBoundingClientRect batches layout reads — avoids forced reflow vs offsetWidth
  function resize() {
    const rect = section!.getBoundingClientRect();
    canvas.width  = Math.round(rect.width);
    canvas.height = Math.round(rect.height);
  }
  // Defer first resize to next rAF — prevents forced reflow at parse time
  requestAnimationFrame(resize);

  // Debounced resize on window change
  let resizeTimer: ReturnType<typeof setTimeout>;
  window.addEventListener('resize', () => {
    clearTimeout(resizeTimer);
    resizeTimer = setTimeout(() => requestAnimationFrame(resize), 120);
  }, { passive: true });

  // Create pixels — scatter them randomly across full height at start
  const pixels = Array.from({ length: COUNT }, () => {
    const size = 3 + Math.floor(Math.random() * 5); // 3–7 px
    return {
      x:       Math.random() * canvas.width,
      y:       Math.random() * canvas.height,        // start spread out
      speed:   0.4 + Math.random() * 1.6,            // px per frame
      size,
      color:   COLORS[Math.floor(Math.random() * COLORS.length)],
      opacity: 0.055 + Math.random() * 0.12,         // 5–17% — subtle
      wobble:  (Math.random() - 0.5) * 0.3,          // slight horizontal drift
    };
  });

  let raf: number;
  function animate() {
    ctx.clearRect(0, 0, canvas.width, canvas.height);

    for (const p of pixels) {
      ctx.globalAlpha = p.opacity;
      ctx.fillStyle   = p.color;
      ctx.fillRect(Math.floor(p.x), Math.floor(p.y), p.size, p.size);

      p.y += p.speed;
      p.x += p.wobble;

      // Reset when off bottom
      if (p.y > canvas.height + p.size) {
        p.y = -p.size - Math.random() * 40;
        p.x = Math.random() * canvas.width;
      }
      // Wrap horizontal
      if (p.x < -p.size)          p.x = canvas.width + p.size;
      if (p.x > canvas.width + p.size) p.x = -p.size;
    }

    raf = requestAnimationFrame(animate);
  }

  animate();

  // Stop animation when section scrolls out of view (perf)
  const observer = new IntersectionObserver(([entry]) => {
    if (entry.isIntersecting) {
      if (!raf) raf = requestAnimationFrame(animate);
    } else {
      cancelAnimationFrame(raf);
      raf = 0;
    }
  }, { threshold: 0 });
  observer.observe(section);
})();
</script>
