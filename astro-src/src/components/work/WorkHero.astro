---
// WorkHero.astro — Chapter 01: The Navigator
---

<section class="work-hero section">
  <div class="speed-lines"></div>
  <div class="paper-texture"></div>

  <div class="container work-hero__inner">
    <!-- Profile Photo -->
    <div class="work-hero__photo-wrap anim-ink-drop">
      <img
        src="/Images/Profile pic.jpg"
        alt="Nihar Ranjan"
        class="work-hero__photo"
        width="220"
        height="220"
      />
      <div class="work-hero__photo-ring"></div>
    </div>

    <!-- Content -->
    <div class="work-hero__content">
      <div class="chapter-label work-hero__chapter">Chapter 01 · The Navigator</div>

      <h1 class="work-hero__name anim-panel-in">
        NIHAR<br/>RANJAN
      </h1>

      <p class="work-hero__title">
        Software Engineer &amp; Tech Lead
      </p>

      <p class="work-hero__tagline">
        Full-stack engineer and tech lead shipping enterprise products in the Microsoft ecosystem —
        React, .NET, Python, Azure.
      </p>

      <div class="work-hero__bubble">
        <div class="speech-bubble">
          "I want to build great things!" ⚡
        </div>
      </div>

      <div class="work-hero__actions">
        <a href="/resume.pdf" download class="btn-manga btn-manga--primary">
          ↓ Download Profile
        </a>
        <a href="#contact" class="btn-manga btn-manga--secondary">
          ✉ Contact Me
        </a>
      </div>

      <div class="work-hero__socials">
        <a href="https://www.linkedin.com/in/ranjannihar/" target="_blank" rel="noopener" title="LinkedIn">
          <i class="fa-brands fa-linkedin"></i>
        </a>
        <a href="https://github.com/nihar840" target="_blank" rel="noopener" title="GitHub">
          <i class="fa-brands fa-github"></i>
        </a>
        <a href="https://www.instagram.com/n_i_h_a_r_m_a_h_a_j_a_n/" target="_blank" rel="noopener" title="Instagram">
          <i class="fa-brands fa-instagram"></i>
        </a>
        <a href="mailto:nrmahajan840@gmail.com" title="Email">
          <i class="fa-solid fa-envelope"></i>
        </a>
      </div>
    </div>
  </div>
</section>

<div class="halftone-divider container"></div>
