          </svg>
        </a>
        <a href="https://www.instagram.com/n_i_h_a_r_m_a_h_a_j_a_n/" target="_blank" rel="noopener noreferrer" title="Instagram" aria-label="Visit Nihar's Instagram profile">
          <svg xmlns="http://www.w3.org/2000/svg" viewBox="0 0 24 24" width="22" height="22" fill="currentColor" aria-hidden="true">
