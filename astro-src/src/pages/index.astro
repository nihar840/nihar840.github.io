---
import Base from '../layouts/Base.astro';
import ZoneToggle from '../components/ZoneToggle';
import WorkHero from '../components/work/WorkHero.astro';
import Skills from '../components/work/Skills.astro';
import Experience from '../components/work/Experience.astro';
import Projects from '../components/work/Projects.astro';
import Contact from '../components/work/Contact.astro';
import AIChat from '../components/AIChat';

import FunHero from '../components/fun/FunHero.astro';
import FluteMaster from '../components/fun/FluteMaster.astro';
import AnimePicks from '../components/fun/AnimePicks.astro';
import Philosophy from '../components/fun/Philosophy.astro';
import SlidingPuzzle from '../components/fun/SlidingPuzzle';
import StickFigures from '../components/StickFigures.astro';

import '../styles/global.css';
import '../styles/manga.css';
import '../styles/animations.css';
---

<Base>
  <!-- ══ ZONE TOGGLE ══ -->
  <ZoneToggle client:load />

  <!-- ══ AI CHAT FLYOUT — floats above both zones ══ -->
  <AIChat client:load />

  <!-- ══ WORK ZONE ══ -->
  <div id="work-zone">
    <nav class="work-nav" aria-label="Section navigation">
      <div class="work-nav__inner container">
        <a class="work-nav__logo" href="#home">NR<span class="work-nav__dot">.</span></a>
        <div class="work-nav__links">
          <a href="#skills">Skills</a>
          <a href="#experience">Experience</a>
          <a href="#projects">Projects</a>
          <a href="#contact">Contact</a>
        </div>
      </div>
    </nav>

    <div id="home"><WorkHero /></div>
    <Skills />
    <Experience />
    <Projects />
    <Contact />
  </div>

  <!-- ══ FUN ZONE ══ -->
  <div id="fun-zone">
    <FunHero />
    <FluteMaster />
    <AnimePicks />
    <Philosophy />
    <section class="fun-section-bg" id="puzzle-section">
      <div class="container">
        <div class="fun-section-head">
          <div class="fun-hero__chapter" style="margin-bottom:8px;">Arc 05 · The Final Challenge</div>
          <h2>🧩 Solve The Puzzle</h2>
          <p>Slide the tiles into order. Prove you're Nakama material! 🏴‍☠️</p>
        </div>
        <SlidingPuzzle client:load />
      </div>
    </section>
    <footer style="text-align:center;padding:24px;font-size:12px;color:var(--fun-text2);border-top:1px solid rgba(244,162,97,0.15);font-family:var(--font-manga);letter-spacing:0.08em;">
      &copy; 2025 NIHAR RANJAN &middot; THE GRAND LINE IS JUST GETTING STARTED &#x1F3F4;&#x200D;&#x2620;&#xFE0F;
    </footer>
  </div>

  <!-- ══ STICK FIGURES — float above both zones ══ -->
  <StickFigures />
</Base>

<style>
/* ─── Work Nav ─── */
.work-nav {
  position: sticky;
  top: 56px;
  z-index: 800;
  background: rgba(245,240,232,0.88);
  border-bottom: 2.5px solid var(--ink);
  backdrop-filter: blur(10px);
  -webkit-backdrop-filter: blur(10px);
  /* Smooth transition when scroll state changes */
  transition: background 0.3s ease, box-shadow 0.3s ease;
}

/* ── Scrolled state: fully opaque + drop shadow + gradient fade below ── */
.work-nav.is-scrolled {
  background: rgba(245,240,232,0.98);
  box-shadow:
    0 4px 0 var(--ink),            /* hard manga-panel shadow */
    0 6px 24px rgba(13,13,13,0.12); /* soft depth shadow */
}

/* Gradient curtain below the nav — content melts behind it elegantly */
.work-nav::after {
  content: '';
  position: absolute;
  top: 100%;
  left: 0;
  right: 0;
  height: 32px;
  background: linear-gradient(to bottom,
    rgba(245,240,232,0.55) 0%,
    rgba(245,240,232,0) 100%);
  pointer-events: none;
  opacity: 0;
  transition: opacity 0.35s ease;
}
.work-nav.is-scrolled::after {
  opacity: 1;
}
.work-nav__inner {
  display: flex;
  align-items: center;
  height: 44px;
  gap: 20px;
}
.work-nav__logo {
  font-family: -apple-system,'Arial Black',Arial,sans-serif;
  font-weight: 900;
  font-size: 18px;
  color: var(--ink);
  letter-spacing: -0.04em;
  flex-shrink: 0;
}
.work-nav__dot { color: #6366f1; }
.work-nav__links { display: flex; gap: 2px; flex: 1; }
.work-nav__links a {
  font-size: 12px;
  font-weight: 700;
  color: var(--ink-soft);
  padding: 5px 11px;
  border-radius: 4px;
  transition: color .15s, background .15s;
  white-space: nowrap;
}
.work-nav__links a:hover, .work-nav__links a.is-active {
  color: var(--accent);
  background: rgba(230,57,70,.07);
}
@media (max-width: 540px) {
  .work-nav__links a { padding: 4px 7px; font-size: 11px; }
}
@media (max-width: 400px) {
  .work-nav__links { overflow-x: auto; }
}
</style>

<script>
/* ══════════════════════════════════════════════
   PORTFOLIO SCRIPTS
   Astro compiles this as a module script (deferred).
   DOM is fully parsed when this runs — no DOMContentLoaded needed.
   ══════════════════════════════════════════════ */

/* ── ZONE RESTORE — runs immediately, no flash ── */
(function restoreZone() {
  const z = sessionStorage.getItem('portfolio-zone');
  if (z === 'fun') {
    document.getElementById('work-zone')?.classList.add('zone-hidden');
    document.getElementById('fun-zone')?.classList.add('zone-visible');
  }
  // Always reset both zones to top — prevents browser scroll-restoration
  // from dumping the user mid-page or at the bottom
  document.getElementById('work-zone')?.scrollTo(0, 0);
  document.getElementById('fun-zone')?.scrollTo(0, 0);
})();

/* ── ANCHOR SCROLL ──────────────────────────────
   Both zones are position:fixed with overflow-y:auto.
   Browser default scroll targets document.body (which never scrolls).
   We intercept clicks and call zone.scrollTo() directly.
   ─────────────────────────────────────────────── */
function initAnchorScroll() {
  const OFFSET = 56 + 44 + 16; // toggle-bar(56) + work-nav(44) + breathing(16)

  document.querySelectorAll('a[href^="#"]').forEach(link => {
    link.addEventListener('click', (e) => {
      const href = (link as HTMLAnchorElement).getAttribute('href') ?? '';
      const id = href.slice(1);
      if (!id) return;

      const target = document.getElementById(id);
      if (!target) return;

      const wz = document.getElementById('work-zone')!;
      const fz = document.getElementById('fun-zone')!;

      // Find which zone contains the target
      const zone = wz.contains(target) ? wz : fz.contains(target) ? fz : null;
      if (!zone) return;

      e.preventDefault();

      // Calculate absolute offset of target from zone's scroll origin
      // offsetTop is relative to the zone (its nearest positioned ancestor)
      let absTop = 0;
      let el: HTMLElement | null = target;
      while (el && el !== zone) {
        absTop += el.offsetTop;
        el = el.offsetParent as HTMLElement | null;
      }

      // Use work-nav offset only for work zone
      const navOffset = zone === wz ? OFFSET : 56 + 16;
      zone.scrollTo({ top: absTop - navOffset, behavior: 'smooth' });
    });
  });
}

/* ── ACTIVE NAV LINK ─────────────────────────── */
function initActiveNav() {
  const wz = document.getElementById('work-zone');
  if (!wz) return;

  const ids = ['home', 'skills', 'experience', 'projects', 'contact'];
  const links = document.querySelectorAll<HTMLAnchorElement>('.work-nav__links a');

  wz.addEventListener('scroll', () => {
    const scrollMid = wz.scrollTop + 120;
    let cur = 'home';

    ids.forEach(id => {
      const el = document.getElementById(id);
      if (el) {
        // Walk up to get offsetTop relative to zone
        let top = 0;
        let node: HTMLElement | null = el;
        while (node && node !== wz) {
          top += node.offsetTop;
          node = node.offsetParent as HTMLElement | null;
        }
        if (top <= scrollMid) cur = id;
      }
    });

    links.forEach(a => {
      a.classList.toggle('is-active', a.getAttribute('href') === `#${cur}`);
    });
  }, { passive: true });
}

/* ── CARD ENTRANCE ANIMATION ───────────────────
   Cards are ALWAYS visible — the class just adds a pop-in effect.
   Uses IntersectionObserver with zone as root for correct detection.
   ─────────────────────────────────────────────── */
function initCardEntrance() {
  const wz = document.getElementById('work-zone');
  const fz = document.getElementById('fun-zone');

  function observeInZone(zone: Element | null) {
    if (!zone) return;
    const obs = new IntersectionObserver(entries => {
      entries.forEach(entry => {
        if (entry.isIntersecting) {
          entry.target.classList.add('card-entered');
          obs.unobserve(entry.target);
        }
      });
    }, {
      root: zone,           // use the zone as the scroll viewport
      threshold: 0.05,
    });

    zone.querySelectorAll('.skill-card, .timeline-card, .project-card, .award-row, .anime-card')
      .forEach(el => obs.observe(el));
  }

  observeInZone(wz);
  observeInZone(fz);
}

/* ── SCROLL SHADOW on work-nav ────────────────────
   Adds .is-scrolled when work-zone has been scrolled past the hero.
   This triggers: fully opaque bg, hard manga shadow, gradient fade-curtain.
   ─────────────────────────────────────────────── */
function initNavScroll() {
  const wz  = document.getElementById('work-zone');
  const nav = document.querySelector('.work-nav') as HTMLElement | null;
  if (!wz || !nav) return;

  const THRESHOLD = 10; // px scrolled before activating

  wz.addEventListener('scroll', () => {
    nav.classList.toggle('is-scrolled', wz.scrollTop > THRESHOLD);
  }, { passive: true });
}

/* ── INIT — module script runs after DOM is parsed ── */
initAnchorScroll();
initActiveNav();
initCardEntrance();
initNavScroll();
</script>
